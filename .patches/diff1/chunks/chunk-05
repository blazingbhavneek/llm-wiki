+@import "tailwindcss";
+
+@theme {
+  --color-bg: #f6f7fb;
+  --color-panel: #ffffff;
+  --color-soft: #f8fafc;
+  --color-soft2: #eef4ff;
+  --color-line: #d8e0ec;
+  --color-line2: #c3cedd;
+  --color-ink: #182033;
+  --color-muted: #66758b;
+  --color-muted2: #91a0b4;
+  --color-blue: #3977f6;
+  --color-orange: #f59e0b;
+  --color-red: #ef476f;
+  --color-green: #10b981;
+  --color-purple: #8b5cf6;
+
+  --radius-none: 0px;
+}
+
+/* Square everything: the design uses no rounded corners. */
+*,
+*::before,
+*::after {
+  border-radius: 0 !important;
+}
+
+html,
+body,
+#root {
+  height: 100%;
+}
+
+body {
+  margin: 0;
+  color: var(--color-ink);
+  background:
+    radial-gradient(circle at 5% 0%, rgba(57, 119, 246, 0.09), transparent 28%),
+    radial-gradient(circle at 95% 0%, rgba(245, 158, 11, 0.08), transparent 25%),
+    linear-gradient(180deg, #fbfcff 0%, var(--color-bg) 100%);
+  font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
+    "Segoe UI", sans-serif;
+  overflow: hidden;
+}
+
+/* ---- graph canvas ---- */
+.graph-grid {
+  background:
+    linear-gradient(90deg, rgba(216, 224, 236, 0.42) 1px, transparent 1px),
+    linear-gradient(180deg, rgba(216, 224, 236, 0.42) 1px, transparent 1px),
+    #fbfcff;
+}
+
+.graph-svg {
+  cursor: grab;
+  touch-action: none;
+  user-select: none;
+}
+.graph-svg.panning {
+  cursor: grabbing;
+}
+
+.cluster-ring {
+  fill-opacity: 1;
+  stroke-width: 2;
+  stroke-dasharray: 6 8;
+  opacity: 0.92;
+}
+.cluster-label {
+  font-size: 30px;
+  font-weight: 800;
+  letter-spacing: 0.01em;
+  fill: #334155;
+  paint-order: stroke;
+  stroke: rgba(255, 255, 255, 0.95);
+  stroke-width: 8px;
+  stroke-linejoin: round;
+}
+
+.edge {
+  stroke: #b9c5d6;
+  stroke-width: 0.65;
+  opacity: 0.42;
+}
+.edge.conflict {
+  stroke: var(--color-red);
+  stroke-width: 1.2;
+  opacity: 0.72;
+}
+.edge.stale {
+  stroke-dasharray: 3 5;
+  opacity: 0.22;
+}
+.edge.support {
+  stroke: var(--color-orange);
+  opacity: 0.44;
+}
+
+.gnode {
+  stroke: rgba(255, 255, 255, 0.88);
+  stroke-width: 1;
+  cursor: pointer;
+  transition: r 0.16s ease, opacity 0.16s ease, filter 0.16s ease;
+}
+.gnode.source {
+  fill: var(--color-blue);
+}
+.gnode.agent {
+  fill: var(--color-orange);
+}
+.gnode.stale {
+  fill: #b6c0ce;
+  opacity: 0.45;
+}
+.gnode.conflict {
+  fill: var(--color-red);
+}
+.gnode:hover {
+  filter: drop-shadow(0 3px 8px rgba(24, 32, 51, 0.22));
+}
+.gnode.current {
+  fill: #111827;
+  stroke: #fff;
+  stroke-width: 2.2;
+  filter: drop-shadow(0 0 15px rgba(57, 119, 246, 0.45));
+}
+.gnode.used {
+  stroke: #111827;
+  stroke-width: 1.6;
+  filter: drop-shadow(0 0 10px rgba(245, 158, 11, 0.34));
+}
+.gnode.dim {
+  opacity: 0.12;
+}
+
+.mini-node {
+  fill: #94a3b8;
+  opacity: 0.7;
+}
+.mini-node.agent {
+  fill: var(--color-orange);
+  opacity: 0.75;
+}
+.mini-node.current {
+  fill: #111827;
+  opacity: 1;
+}
+.mini-viewport {
+  fill: rgba(57, 119, 246, 0.09);
+  stroke: var(--color-blue);
+  stroke-width: 8;
+  vector-effect: non-scaling-stroke;
+}
+
